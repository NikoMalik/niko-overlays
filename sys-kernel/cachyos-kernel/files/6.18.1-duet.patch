diff --git a/init/Kconfig b/init/Kconfig
index e5ae1c5021..ac66718289 100644
--- a/init/Kconfig
+++ b/init/Kconfig
@@ -1122,6 +1122,23 @@ config SCHED_WAVL
 
 	  If unsure, say Y.
 
+config SCHED_DUET
+	bool "Two-level group/task scheduler architecture"
+	depends on FAIR_GROUP_SCHED
+	default y
+	help
+	  This option replaces the polymorphic sched_entity/cfs_rq design
+	  with a two-level architecture where group entities and task entities
+	  are completely separate types in separate runqueues:
+
+	    group_rq  contains only  group_entity  (groups compete with groups)
+	    task_rq   contains only  sched_entity  (tasks compete with tasks)
+
+	  This eliminates all entity_is_task() runtime type checks and
+	  for_each_sched_entity() mixed hierarchy walks.
+
+	  If unsure, say Y.
+
 config CFS_BANDWIDTH
 	bool "CPU bandwidth provisioning for FAIR_GROUP_SCHED"
 	depends on FAIR_GROUP_SCHED
