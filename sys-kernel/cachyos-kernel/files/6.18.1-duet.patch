diff --git a/kernel/sched/duet.c b/kernel/sched/duet.c
new file mode 100644
index 0000000000..d4aef5433e
--- /dev/null
+++ b/kernel/sched/duet.c
@@ -0,0 +1,2403 @@
+#ifdef CONFIG_SCHED_DUET
+
+#define SCHED_DUET_PROGNAME	"DUET (DUal Entity Trees) CPU Scheduler Modification"
+#define SCHED_DUET_AUTHOR	"Masahito Suzuki"
+
+#define SCHED_DUET_VERSION	"0.0.2"
+
+/*
+ * Two-level scheduler: initialization helpers.
+ */
+
+static void init_group_rq(struct group_rq *grq, struct rq *rq,
+			   struct task_group *tg)
+{
+	grq->groups_timeline = WAVL_ROOT_CACHED;
+	grq->zero_vruntime = (u64)(-(1LL << 20));
+	grq->rq = rq;
+	grq->tg = tg;
+	grq->curr = NULL;
+	grq->next = NULL;
+	grq->nr_queued = 0;
+	grq->h_nr_queued = 0;
+	grq->h_nr_runnable = 0;
+	grq->h_nr_idle = 0;
+#ifdef CONFIG_CFS_BANDWIDTH
+	grq->runtime_enabled = 0;
+	grq->runtime_remaining = 0;
+	grq->throttled = false;
+	grq->throttle_count = 0;
+	INIT_LIST_HEAD(&grq->throttled_list);
+#endif
+}
+
+static void init_task_rq(struct task_rq *trq, struct rq *rq,
+			 struct task_group *tg, struct group_entity *owner)
+{
+	trq->tasks_timeline = RB_ROOT_CACHED;
+	trq->zero_vruntime = (u64)(-(1LL << 20));
+	trq->rq = rq;
+	trq->tg = tg;
+	trq->owner = owner;
+	trq->curr = NULL;
+	trq->next = NULL;
+	trq->nr_queued = 0;
+	trq->on_list = 0;
+	trq->tg_load_avg_contrib = 0;
+	trq->last_update_tg_load_avg = 0;
+	INIT_LIST_HEAD(&trq->leaf_trq_list);
+}
+
+static void init_group_entity(struct group_entity *ge, struct task_group *tg,
+			      int cpu, struct group_entity *parent)
+{
+	struct rq *rq = cpu_rq(cpu);
+
+	memset(ge, 0, sizeof(*ge));
+
+	ge->load.weight = tg->shares;
+	ge->load.inv_weight = 0;	/* computed on demand */
+	ge->slice = sysctl_sched_base_slice;
+	WAVL_CLEAR_NODE(&ge->run_node);
+	INIT_LIST_HEAD(&ge->group_node);
+
+	ge->tg = tg;
+	ge->parent = parent;
+	ge->depth = parent ? parent->depth + 1 : 0;
+
+	/* grq this entity is queued on */
+	if (parent && parent->my_grq)
+		ge->grq = parent->my_grq;
+	else
+		ge->grq = &rq->grq;	/* root level */
+
+	/* child pointers set by caller (leaf vs intermediate) */
+	ge->my_grq = NULL;
+	ge->my_trq = NULL;
+}
+
+static inline void list_del_leaf_trq(struct task_rq *trq);
+
+static void free_duet_sched_group(struct task_group *tg)
+{
+	int i;
+
+	for_each_possible_cpu(i) {
+		if (tg->trq && tg->trq[i]) {
+			/*
+			 * Remove from leaf_trq_list before freeing.
+			 * Without this, __update_blocked_fair_duet
+			 * iterates stale list entries → use-after-free.
+			 */
+			list_del_leaf_trq(tg->trq[i]);
+			kfree(tg->trq[i]);
+		}
+		if (tg->grq)
+			kfree(tg->grq[i]);
+		if (tg->ge)
+			kfree(tg->ge[i]);
+	}
+
+	kfree(tg->trq);
+	kfree(tg->grq);
+	kfree(tg->ge);
+}
+
+/*
+ * Allocate two-level scheduler structures for a task group.
+ * All groups get a group_entity. Leaf groups (those with tasks)
+ * get a task_rq. Intermediate groups get a child group_rq.
+ *
+ * Initially all groups are treated as leaf groups (they get a task_rq).
+ * If a child group is later added, the parent can be promoted to
+ * intermediate (adds a group_rq).
+ */
+static int alloc_duet_sched_group(struct task_group *tg,
+				      struct task_group *parent)
+{
+	struct group_entity *ge;
+	struct task_rq *trq;
+	int i;
+
+	tg->ge = kcalloc(nr_cpu_ids, sizeof(ge), GFP_KERNEL);
+	if (!tg->ge)
+		return 0;
+	tg->trq = kcalloc(nr_cpu_ids, sizeof(trq), GFP_KERNEL);
+	if (!tg->trq)
+		goto err_free_ge;
+	/* grq array allocated lazily when group becomes intermediate */
+	tg->grq = NULL;
+
+	for_each_possible_cpu(i) {
+		struct group_entity *parent_ge = parent->ge ? parent->ge[i] : NULL;
+
+		ge = kzalloc_node(sizeof(*ge), GFP_KERNEL, cpu_to_node(i));
+		if (!ge)
+			goto err;
+		tg->ge[i] = ge;
+
+		trq = kzalloc_node(sizeof(*trq), GFP_KERNEL, cpu_to_node(i));
+		if (!trq)
+			goto err;
+		tg->trq[i] = trq;
+
+		init_group_entity(ge, tg, i, parent_ge);
+		init_task_rq(trq, cpu_rq(i), tg, ge);
+
+		/* Leaf group: group_entity owns a task_rq */
+		ge->my_trq = trq;
+	}
+
+	return 1;
+
+err:
+	free_duet_sched_group(tg);
+	return 0;
+
+err_free_ge:
+	kfree(tg->ge);
+	tg->ge = NULL;
+	return 0;
+}
+
+/*
+ * Walk up the group_entity ancestry chain.  Stops automatically at
+ * the flat-hierarchy boundary (parent in the same group_rq).
+ * The loop variable @ge is consumed; use a temporary if needed.
+ */
+static inline struct group_entity *
+__ge_next_ancestor(struct group_entity *ge)
+{
+	if (!ge->parent || ge->parent->grq == ge->grq)
+		return NULL;
+	return ge->parent;
+}
+
+#define for_each_ge_ancestor(ge) \
+	for (; ge; ge = __ge_next_ancestor(ge))
+
+/* ===================================================================
+ * Two-level scheduler: EEVDF runqueue engine template
+ * =================================================================== */
+
+/*
+ * EEVDF runqueue engine template.
+ *
+ * Generates the complete set of EEVDF operations for a runqueue type.
+ * Instantiated once for group_rq (grq) and once for task_rq (trq).
+ * This eliminates the bug-prone duplication between the two levels.
+ */
+#define DEFINE_EEVDF_OPS(PFX, RQ_T, ENT_T, TIMELINE, NODE2ENT,		\
+			 LESS_FN, BEFORE_FN, AUG_CB)			\
+									\
+static inline s64 PFX##_entity_key(RQ_T *rq, ENT_T *e)			\
+{									\
+	return (s64)(e->vruntime - rq->zero_vruntime);			\
+}									\
+									\
+static void PFX##_avg_vruntime_add(RQ_T *rq, ENT_T *e)			\
+{									\
+	unsigned long w = scale_load_down(e->load.weight);		\
+	s64 key = PFX##_entity_key(rq, e);				\
+									\
+	rq->avg_vruntime += key * w;					\
+	rq->avg_load += w;						\
+}									\
+									\
+static void PFX##_avg_vruntime_sub(RQ_T *rq, ENT_T *e)			\
+{									\
+	unsigned long w = scale_load_down(e->load.weight);		\
+	s64 key = PFX##_entity_key(rq, e);				\
+									\
+	rq->avg_vruntime -= key * w;					\
+	rq->avg_load -= w;						\
+}									\
+									\
+static inline void PFX##_avg_vruntime_update(RQ_T *rq, s64 delta)	\
+{									\
+	rq->avg_vruntime -= rq->avg_load * delta;			\
+}									\
+									\
+static int PFX##_vruntime_eligible(RQ_T *rq, u64 vruntime)		\
+{									\
+	ENT_T *curr = rq->curr;					\
+	s64 avg = rq->avg_vruntime;					\
+	long load = rq->avg_load;					\
+									\
+	if (curr && curr->on_rq) {					\
+		unsigned long w = scale_load_down(curr->load.weight);	\
+									\
+		avg += PFX##_entity_key(rq, curr) * w;			\
+		load += w;						\
+	}								\
+									\
+	return avg >= (s64)(vruntime - rq->zero_vruntime) * load;	\
+}									\
+									\
+static inline int PFX##_entity_eligible(RQ_T *rq, ENT_T *e)		\
+{									\
+	return PFX##_vruntime_eligible(rq, e->vruntime);		\
+}									\
+									\
+static u64 PFX##_avg_vruntime(RQ_T *rq)				\
+{									\
+	ENT_T *curr = rq->curr;					\
+	s64 avg = rq->avg_vruntime;					\
+	long load = rq->avg_load;					\
+									\
+	if (curr && curr->on_rq) {					\
+		unsigned long w = scale_load_down(curr->load.weight);	\
+									\
+		avg += PFX##_entity_key(rq, curr) * w;			\
+		load += w;						\
+	}								\
+									\
+	if (load) {							\
+		if (avg < 0)						\
+			avg -= load - 1;				\
+		avg = div_s64(avg, load);				\
+	}								\
+									\
+	return rq->zero_vruntime + avg;					\
+}									\
+									\
+static void PFX##_update_zero_vruntime(RQ_T *rq)			\
+{									\
+	u64 vruntime = PFX##_avg_vruntime(rq);				\
+	s64 delta = (s64)(vruntime - rq->zero_vruntime);		\
+									\
+	PFX##_avg_vruntime_update(rq, delta);				\
+	rq->zero_vruntime = vruntime;					\
+}									\
+									\
+static void __##PFX##_enqueue_entity(RQ_T *rq, ENT_T *e)		\
+{									\
+	PFX##_avg_vruntime_add(rq, e);					\
+	PFX##_update_zero_vruntime(rq);					\
+	e->min_vruntime = e->vruntime;					\
+	e->min_slice = e->slice;					\
+	rb_add_augmented_cached(&e->run_node, &rq->TIMELINE,		\
+				LESS_FN, &AUG_CB);			\
+}									\
+									\
+static void __##PFX##_dequeue_entity(RQ_T *rq, ENT_T *e)		\
+{									\
+	rb_erase_augmented_cached(&e->run_node, &rq->TIMELINE,		\
+				  &AUG_CB);				\
+	PFX##_avg_vruntime_sub(rq, e);					\
+	PFX##_update_zero_vruntime(rq);					\
+}									\
+									\
+static ENT_T *__##PFX##_pick_eevdf(RQ_T *rq)				\
+{									\
+	struct rb_node *node = rq->TIMELINE.rb_root.rb_node;		\
+	struct rb_node *leftmost = rb_first_cached(&rq->TIMELINE);	\
+	ENT_T *e;							\
+	ENT_T *curr = rq->curr;					\
+	ENT_T *best = NULL;						\
+									\
+	if (!leftmost)							\
+		e = NULL;						\
+	else								\
+		e = NODE2ENT(leftmost);					\
+									\
+	if (rq->nr_queued == 1)						\
+		return curr && curr->on_rq ? curr : e;			\
+									\
+	if (curr && (!curr->on_rq ||					\
+		     !PFX##_entity_eligible(rq, curr)))			\
+		curr = NULL;						\
+									\
+	if (e && PFX##_entity_eligible(rq, e)) {			\
+		best = e;						\
+		goto found;						\
+	}								\
+									\
+	while (node) {							\
+		struct rb_node *left = node->rb_left;			\
+									\
+		if (left && PFX##_vruntime_eligible(rq,			\
+				NODE2ENT(left)->min_vruntime)) {	\
+			node = left;					\
+			continue;					\
+		}							\
+									\
+		e = NODE2ENT(node);					\
+									\
+		if (PFX##_entity_eligible(rq, e)) {			\
+			best = e;					\
+			break;						\
+		}							\
+									\
+		node = node->rb_right;					\
+	}								\
+found:									\
+	if (!best || (curr && BEFORE_FN(curr, best)))			\
+		best = curr;						\
+									\
+	return best;							\
+}									\
+									\
+static ENT_T *PFX##_pick_next_entity(RQ_T *rq)				\
+{									\
+	ENT_T *next = rq->next;					\
+									\
+	if (next && next->on_rq &&					\
+	    PFX##_entity_eligible(rq, next)) {				\
+		rq->next = NULL;					\
+		return next;						\
+	}								\
+	rq->next = NULL;						\
+	return __##PFX##_pick_eevdf(rq);				\
+}									\
+									\
+static void PFX##_set_next_entity(RQ_T *rq, ENT_T *e)			\
+{									\
+	if (e->on_rq)							\
+		__##PFX##_dequeue_entity(rq, e);			\
+	rq->curr = e;							\
+}									\
+									\
+static void PFX##_put_prev_entity(RQ_T *rq, ENT_T *prev)		\
+{									\
+	if (prev->on_rq)						\
+		__##PFX##_enqueue_entity(rq, prev);			\
+	rq->curr = NULL;						\
+}
+
+/* ===================================================================
+ * Two-level scheduler: group_rq EEVDF operations
+ * =================================================================== */
+
+/*
+ * group_entity helpers — mirror the sched_entity EEVDF helpers
+ * but operate on group_rq + group_entity instead of cfs_rq + sched_entity.
+ */
+
+#define __grq_node_2_ge(node) \
+	wavl_entry((node), struct group_entity, run_node)
+
+static inline bool ge_before(const struct group_entity *a,
+			     const struct group_entity *b)
+{
+	return (s64)(a->deadline - b->deadline) < 0;
+}
+
+static inline bool __ge_less(struct wavl_node *a, const struct wavl_node *b)
+{
+	return ge_before(__grq_node_2_ge(a), __grq_node_2_ge(b));
+}
+
+static inline void __ge_min_vruntime_update(struct group_entity *ge,
+					    struct wavl_node *node)
+{
+	if (node) {
+		struct group_entity *rge = __grq_node_2_ge(node);
+
+		if ((s64)(ge->min_vruntime - rge->min_vruntime) > 0)
+			ge->min_vruntime = rge->min_vruntime;
+	}
+}
+
+static inline void __ge_min_slice_update(struct group_entity *ge,
+					 struct wavl_node *node)
+{
+	if (node) {
+		struct group_entity *rge = __grq_node_2_ge(node);
+
+		if (rge->min_slice < ge->min_slice)
+			ge->min_slice = rge->min_slice;
+	}
+}
+
+static inline bool ge_min_vruntime_update(struct group_entity *ge, bool exit)
+{
+	u64 old_min_vruntime = ge->min_vruntime;
+	u64 old_min_slice = ge->min_slice;
+	struct wavl_node *node = &ge->run_node;
+
+	ge->min_vruntime = ge->vruntime;
+	__ge_min_vruntime_update(ge, node->wavl_right);
+	__ge_min_vruntime_update(ge, node->wavl_left);
+
+	ge->min_slice = ge->slice;
+	__ge_min_slice_update(ge, node->wavl_right);
+	__ge_min_slice_update(ge, node->wavl_left);
+
+	return ge->min_vruntime == old_min_vruntime &&
+	       ge->min_slice == old_min_slice;
+}
+
+WAVL_DECLARE_CALLBACKS(static, ge_min_vruntime_cb, struct group_entity,
+		       run_node, min_vruntime, ge_min_vruntime_update);
+
+/* --- Group-level EEVDF instantiation (WAVL tree) --- */
+
+/*
+ * DEFINE_EEVDF_OPS_WAVL — same as DEFINE_EEVDF_OPS but uses the
+ * WAVL tree API (wavl_add_augmented_cached, wavl_erase_augmented_cached,
+ * wavl_first_cached, struct wavl_node) instead of the rb-tree API.
+ * Used for group_rq only; task_rq continues to use the rb-tree variant.
+ */
+#define DEFINE_EEVDF_OPS_WAVL(PFX, RQ_T, ENT_T, TIMELINE, NODE2ENT,	\
+			      LESS_FN, BEFORE_FN, AUG_CB)		\
+									\
+static inline s64 PFX##_entity_key(RQ_T *rq, ENT_T *e)			\
+{									\
+	return (s64)(e->vruntime - rq->zero_vruntime);			\
+}									\
+									\
+static void PFX##_avg_vruntime_add(RQ_T *rq, ENT_T *e)			\
+{									\
+	unsigned long w = scale_load_down(e->load.weight);		\
+	s64 key = PFX##_entity_key(rq, e);				\
+									\
+	rq->avg_vruntime += key * w;					\
+	rq->avg_load += w;						\
+}									\
+									\
+static void PFX##_avg_vruntime_sub(RQ_T *rq, ENT_T *e)			\
+{									\
+	unsigned long w = scale_load_down(e->load.weight);		\
+	s64 key = PFX##_entity_key(rq, e);				\
+									\
+	rq->avg_vruntime -= key * w;					\
+	rq->avg_load -= w;						\
+}									\
+									\
+static inline void PFX##_avg_vruntime_update(RQ_T *rq, s64 delta)	\
+{									\
+	rq->avg_vruntime -= rq->avg_load * delta;			\
+}									\
+									\
+static int PFX##_vruntime_eligible(RQ_T *rq, u64 vruntime)		\
+{									\
+	ENT_T *curr = rq->curr;					\
+	s64 avg = rq->avg_vruntime;					\
+	long load = rq->avg_load;					\
+									\
+	if (curr && curr->on_rq) {					\
+		unsigned long w = scale_load_down(curr->load.weight);	\
+									\
+		avg += PFX##_entity_key(rq, curr) * w;			\
+		load += w;						\
+	}								\
+									\
+	return avg >= (s64)(vruntime - rq->zero_vruntime) * load;	\
+}									\
+									\
+static inline int PFX##_entity_eligible(RQ_T *rq, ENT_T *e)		\
+{									\
+	return PFX##_vruntime_eligible(rq, e->vruntime);		\
+}									\
+									\
+static u64 PFX##_avg_vruntime(RQ_T *rq)				\
+{									\
+	ENT_T *curr = rq->curr;					\
+	s64 avg = rq->avg_vruntime;					\
+	long load = rq->avg_load;					\
+									\
+	if (curr && curr->on_rq) {					\
+		unsigned long w = scale_load_down(curr->load.weight);	\
+									\
+		avg += PFX##_entity_key(rq, curr) * w;			\
+		load += w;						\
+	}								\
+									\
+	if (load) {							\
+		if (avg < 0)						\
+			avg -= load - 1;				\
+		avg = div_s64(avg, load);				\
+	}								\
+									\
+	return rq->zero_vruntime + avg;					\
+}									\
+									\
+static void PFX##_update_zero_vruntime(RQ_T *rq)			\
+{									\
+	u64 vruntime = PFX##_avg_vruntime(rq);				\
+	s64 delta = (s64)(vruntime - rq->zero_vruntime);		\
+									\
+	PFX##_avg_vruntime_update(rq, delta);				\
+	rq->zero_vruntime = vruntime;					\
+}									\
+									\
+static void __##PFX##_enqueue_entity(RQ_T *rq, ENT_T *e)		\
+{									\
+	PFX##_avg_vruntime_add(rq, e);					\
+	PFX##_update_zero_vruntime(rq);					\
+	e->min_vruntime = e->vruntime;					\
+	e->min_slice = e->slice;					\
+	wavl_add_augmented_cached(&e->run_node, &rq->TIMELINE,		\
+				  LESS_FN, &AUG_CB);			\
+}									\
+									\
+static void __##PFX##_dequeue_entity(RQ_T *rq, ENT_T *e)		\
+{									\
+	wavl_erase_augmented_cached(&e->run_node, &rq->TIMELINE,	\
+				    &AUG_CB);				\
+	PFX##_avg_vruntime_sub(rq, e);					\
+	PFX##_update_zero_vruntime(rq);					\
+}									\
+									\
+static ENT_T *__##PFX##_pick_eevdf(RQ_T *rq)				\
+{									\
+	struct wavl_node *node = rq->TIMELINE.wavl_root.wavl_node;	\
+	struct wavl_node *leftmost = wavl_first_cached(&rq->TIMELINE);	\
+	ENT_T *e;							\
+	ENT_T *curr = rq->curr;					\
+	ENT_T *best = NULL;						\
+									\
+	if (!leftmost)							\
+		e = NULL;						\
+	else								\
+		e = NODE2ENT(leftmost);					\
+									\
+	if (rq->nr_queued == 1)						\
+		return curr && curr->on_rq ? curr : e;			\
+									\
+	if (curr && (!curr->on_rq ||					\
+		     !PFX##_entity_eligible(rq, curr)))			\
+		curr = NULL;						\
+									\
+	if (e && PFX##_entity_eligible(rq, e)) {			\
+		best = e;						\
+		goto found;						\
+	}								\
+									\
+	while (node) {							\
+		struct wavl_node *left = node->wavl_left;		\
+									\
+		if (left && PFX##_vruntime_eligible(rq,			\
+				NODE2ENT(left)->min_vruntime)) {	\
+			node = left;					\
+			continue;					\
+		}							\
+									\
+		e = NODE2ENT(node);					\
+									\
+		if (PFX##_entity_eligible(rq, e)) {			\
+			best = e;					\
+			break;						\
+		}							\
+									\
+		node = node->wavl_right;				\
+	}								\
+found:									\
+	if (!best || (curr && BEFORE_FN(curr, best)))			\
+		best = curr;						\
+									\
+	return best;							\
+}									\
+									\
+static ENT_T *PFX##_pick_next_entity(RQ_T *rq)				\
+{									\
+	ENT_T *next = rq->next;					\
+									\
+	if (next && next->on_rq &&					\
+	    PFX##_entity_eligible(rq, next)) {				\
+		rq->next = NULL;					\
+		return next;						\
+	}								\
+	rq->next = NULL;						\
+	return __##PFX##_pick_eevdf(rq);				\
+}									\
+									\
+static void PFX##_set_next_entity(RQ_T *rq, ENT_T *e)			\
+{									\
+	if (e->on_rq)							\
+		__##PFX##_dequeue_entity(rq, e);			\
+	rq->curr = e;							\
+}									\
+									\
+static void PFX##_put_prev_entity(RQ_T *rq, ENT_T *prev)		\
+{									\
+	if (prev->on_rq)						\
+		__##PFX##_enqueue_entity(rq, prev);			\
+	rq->curr = NULL;						\
+}
+
+DEFINE_EEVDF_OPS_WAVL(grq, struct group_rq, struct group_entity,
+		      groups_timeline, __grq_node_2_ge,
+		      __ge_less, ge_before, ge_min_vruntime_cb)
+
+/* Checked versions with state validation */
+static void grq_set_next_entity_checked(struct group_rq *grq,
+					struct group_entity *ge)
+{
+	WARN_ON_ONCE(grq->curr == ge); /* double set_next */
+	grq_set_next_entity(grq, ge);
+}
+
+static void grq_put_prev_entity_checked(struct group_rq *grq,
+					 struct group_entity *prev)
+{
+	WARN_ON_ONCE(grq->curr != prev); /* putting non-current */
+	grq_put_prev_entity(grq, prev);
+}
+
+/* Forward declarations: defined after task_rq EEVDF instantiation */
+static inline u64 ge_child_min_deadline(struct group_entity *ge);
+static void propagate_deadline_up(struct group_entity *ge);
+
+/*
+ * update_curr_group — update the current group_entity's vruntime
+ * from accumulated consumed time.
+ *
+ * Key difference from update_cfs_group: group weight is simply tg->shares.
+ * No calc_group_shares() approximation needed.
+ */
+static void update_curr_group(struct group_rq *grq)
+{
+	struct group_entity *curr = grq->curr;
+	u64 consumed;
+	u64 vruntime_delta;
+
+	if (!curr || !curr->on_rq)
+		return;
+
+	consumed = curr->consumed;
+	if (!consumed)
+		return;
+
+	curr->consumed = 0;
+	curr->sum_exec_runtime += consumed;
+
+	if (curr->load.weight != NICE_0_LOAD)
+		vruntime_delta = __calc_delta(consumed, NICE_0_LOAD, &curr->load);
+	else
+		vruntime_delta = consumed;
+	curr->vruntime += vruntime_delta;
+
+	/*
+	 * Deadline propagated from children's min_deadline.
+	 * Eligibility (vruntime-based) handles group fairness;
+	 * deadline (children's min) enables urgency-aware selection.
+	 */
+	curr->deadline = ge_child_min_deadline(curr);
+}
+
+/* ===================================================================
+ * Two-level scheduler: task_rq EEVDF operations
+ *
+ * These mirror the existing cfs_rq task operations but operate on
+ * task_rq. No group entities ever appear here — the type guarantees it.
+ * =================================================================== */
+
+/* --- Task-level EEVDF instantiation --- */
+DEFINE_EEVDF_OPS(trq, struct task_rq, struct sched_entity,
+		 tasks_timeline, __node_2_se,
+		 __entity_less, entity_before, min_vruntime_cb)
+
+/*
+ * update_curr_task — update the currently running task's vruntime.
+ * Returns delta_exec for upward propagation to group hierarchy.
+ * No entity_is_task() check needed — task_rq only contains tasks.
+ */
+static u64 update_curr_task(struct task_rq *trq, u64 now)
+{
+	struct sched_entity *curr = trq->curr;
+	u64 delta_exec;
+
+	if (!curr || !curr->on_rq)
+		return 0;
+
+	delta_exec = now - curr->exec_start;
+	if ((s64)delta_exec <= 0)
+		return 0;
+
+	curr->exec_start = now;
+	curr->sum_exec_runtime += delta_exec;
+
+	curr->vruntime += calc_delta_fair(delta_exec, curr);
+
+	if ((s64)(curr->vruntime - curr->deadline) >= 0) {
+		curr->deadline = curr->vruntime +
+			calc_delta_fair(curr->slice, curr);
+	}
+
+#ifdef CONFIG_SCHED_BORE
+	/* BORE: update burst penalty for the running task */
+	if (static_branch_likely(&sched_bore_key)) {
+		struct task_struct *p = task_of(curr);
+
+		update_curr_bore(p, delta_exec);
+	}
+#endif
+
+	/* PELT: update running task and task_rq averages */
+	{
+		u64 pelt_now = rq_clock_pelt(trq->rq);
+
+		__update_load_avg_trq_se(pelt_now, trq, curr);
+		__update_load_avg_trq(pelt_now, trq);
+	}
+
+	return delta_exec;
+}
+
+/* Forward declarations: defined after enqueue/dequeue section */
+static void update_entity_lag_duet(struct task_rq *trq,
+				   struct sched_entity *se);
+static void place_task_duet(struct task_rq *trq, struct sched_entity *se,
+			    int flags);
+
+/*
+ * reweight_task_entity — change a task's weight with proper lag/deadline
+ * scaling, mirroring vanilla reweight_entity().
+ *
+ * Because vlag = V - v_i while lag_i = w_i * (V - v_i), changing w_i
+ * requires scaling vlag by old_w / new_w so that the real lag (in
+ * service units) is preserved.  The same applies to relative deadlines.
+ */
+static void __maybe_unused reweight_task_entity(struct task_rq *trq,
+						struct sched_entity *se,
+						unsigned long weight)
+{
+	unsigned long old_weight = se->load.weight;
+	bool curr = trq->curr == se;
+	bool on_rq = se->on_rq;
+
+	if (old_weight == weight)
+		return;
+
+	if (on_rq) {
+		update_entity_lag_duet(trq, se);
+		se->deadline -= se->vruntime;
+		se->rel_deadline = 1;
+		trq->nr_queued--;
+		if (!curr)
+			__trq_dequeue_entity(trq, se);
+		update_load_sub(&trq->load, old_weight);
+	}
+
+	/* Scale vlag and relative deadline by weight ratio */
+	se->vlag = div_s64(se->vlag * old_weight, weight);
+	if (se->rel_deadline)
+		se->deadline = div_s64(se->deadline * old_weight, weight);
+
+	se->load.weight = weight;
+	se->load.inv_weight = 0;	/* recomputed on demand */
+
+	if (on_rq) {
+		place_task_duet(trq, se, 0);
+		update_load_add(&trq->load, weight);
+		if (!curr)
+			__trq_enqueue_entity(trq, se);
+		trq->nr_queued++;
+	}
+}
+
+/*
+ * BORE integration: reweight a task via the two-level path.
+ * Called from bore.c's reweight_task_by_prio().
+ * Not static — needs to be accessible from bore.o.
+ */
+#ifdef CONFIG_SCHED_BORE
+void reweight_task_duet(struct task_struct *p, unsigned long weight)
+{
+	struct task_group *tg = task_group(p);
+	int cpu = task_cpu(p);
+	struct task_rq *trq = tg->trq[cpu];
+	struct group_entity *ge = tg->ge[cpu];
+	struct sched_entity *se = &p->se;
+
+	reweight_task_entity(trq, se, weight);
+
+	/* Task deadline may have changed — propagate up */
+	propagate_deadline_up(ge);
+}
+#endif
+
+/* ===================================================================
+ * Two-level scheduler: min_deadline propagation
+ *
+ * Propagate the minimum task deadline from children upward to
+ * group_entity.  This enables globally-optimal deadline selection:
+ *
+ *   - Eligibility (group_vrt based) ensures group weight fairness
+ *   - Deadline (min_deadline from children) ensures urgency awareness
+ *
+ * At the group_rq level, pick_eevdf selects among ELIGIBLE groups
+ * the one whose subtree contains the task with the smallest deadline.
+ * =================================================================== */
+
+/*
+ * Get the minimum deadline among all tasks in a task_rq.
+ * The tasks_timeline rbtree is sorted by deadline, so leftmost = min.
+ * Also considers curr which is dequeued from the tree while running.
+ */
+static u64 trq_min_deadline(struct task_rq *trq)
+{
+	struct rb_node *leftmost = rb_first_cached(&trq->tasks_timeline);
+	struct sched_entity *curr = trq->curr;
+	u64 min_dl = U64_MAX;
+
+	if (leftmost)
+		min_dl = __node_2_se(leftmost)->deadline;
+
+	if (curr && curr->on_rq && (s64)(curr->deadline - min_dl) < 0)
+		min_dl = curr->deadline;
+
+	return min_dl;
+}
+
+/*
+ * Get the minimum deadline among all group_entities in a group_rq.
+ * Each ge's deadline is already the min_deadline of its subtree,
+ * so the minimum here is the global min across all descendant tasks.
+ */
+static u64 grq_min_deadline(struct group_rq *grq)
+{
+	struct wavl_node *leftmost = wavl_first_cached(&grq->groups_timeline);
+	struct group_entity *curr = grq->curr;
+	u64 min_dl = U64_MAX;
+
+	if (leftmost)
+		min_dl = __grq_node_2_ge(leftmost)->deadline;
+
+	if (curr && curr->on_rq && (s64)(curr->deadline - min_dl) < 0)
+		min_dl = curr->deadline;
+
+	return min_dl;
+}
+
+/*
+ * Get the min_deadline from a group_entity's children.
+ */
+static inline u64 ge_child_min_deadline(struct group_entity *ge)
+{
+	if (ge->my_trq)
+		return trq_min_deadline(ge->my_trq);
+	if (ge->my_grq)
+		return grq_min_deadline(ge->my_grq);
+	return U64_MAX;
+}
+
+/*
+ * Propagate min_deadline from children up through the group hierarchy.
+ * At each level, update ge->deadline and reposition in the parent
+ * group_rq rbtree if necessary.  Stops when deadline doesn't change.
+ */
+static void __maybe_unused propagate_deadline_up(struct group_entity *ge)
+{
+	for_each_ge_ancestor(ge) {
+		struct group_rq *grq = ge->grq;
+		u64 new_dl = ge_child_min_deadline(ge);
+
+		if (ge->deadline == new_dl)
+			return; /* no change, stop propagation */
+
+		if (grq->curr == ge) {
+			/* not in tree, just update */
+			ge->deadline = new_dl;
+		} else if (ge->on_rq) {
+			/* in tree, reposition */
+			__grq_dequeue_entity(grq, ge);
+			ge->deadline = new_dl;
+			__grq_enqueue_entity(grq, ge);
+		} else {
+			ge->deadline = new_dl;
+		}
+	}
+}
+
+/* ===================================================================
+ * Two-level scheduler: pick_task — type-safe hierarchy descent
+ *
+ * root group_rq → pick group_entity → descend child group_rq →
+ * ... → leaf group_entity → pick task from task_rq
+ * =================================================================== */
+
+/*
+ * Descend through the group hierarchy to find the leaf task_rq.
+ * At each level, pick the EEVDF-best group_entity and follow
+ * its child pointer (my_grq for intermediate, my_trq for leaf).
+ *
+ * IMPORTANT: This is a PEEK-ONLY function — it does NOT modify tree
+ * state (no grq_set_next_entity / trq_set_next_entity).  The actual
+ * commit (rb_erase + set curr) is deferred to set_next_duet(),
+ * which is called from set_next_task_fair().  This satisfies the
+ * pick_task contract required by the core scheduler: pick_task may be
+ * called without a preceding put_prev (e.g. DL-server, SCHED_CORE).
+ */
+/*
+ * Update accounting for the currently running entity.
+ * Called before pick to ensure curr's vruntime is up to date.
+ * Separated from pick_task_duet to make side effects explicit.
+ */
+static void update_duet_curr(struct rq *rq)
+{
+	struct group_rq *grq = &rq->grq;
+
+	if (grq->curr)
+		update_curr_group(grq);
+}
+
+static struct task_struct *pick_task_duet(struct rq *rq)
+{
+	struct group_rq *grq = &rq->grq;
+	struct group_entity *ge;
+	struct task_rq *trq;
+	struct sched_entity *se;
+
+	if (!grq->nr_queued)
+		return NULL;
+
+	/* Accounting update separated to update_duet_curr() */
+	update_duet_curr(rq);
+
+	ge = grq_pick_next_entity(grq);
+	if (!ge)
+		return NULL;
+
+	/* Descend through intermediate group levels (peek only) */
+	while (ge->my_grq) {
+		struct group_rq *child_grq = ge->my_grq;
+
+		update_curr_group(child_grq);
+		ge = grq_pick_next_entity(child_grq);
+		if (!ge)
+			return NULL;
+	}
+
+	/* Leaf level: pick task from task_rq */
+	trq = ge->my_trq;
+	if (!trq || !trq->nr_queued)
+		return NULL;
+
+	update_curr_task(trq, rq_clock_task(rq));
+	se = trq_pick_next_entity(trq);
+	if (!se)
+		return NULL;
+
+	return task_of(se);
+}
+
+/*
+ * Commit the pick: dequeue entities from their trees and set as current.
+ * Called from set_next_task_fair() after pick_task_duet() peeked.
+ *
+ * Walks up the group_entity chain from leaf to root, calling
+ * grq_set_next_entity() at each level, then sets the task entity.
+ */
+/*
+ * trq_min_slice — minimum slice among all entities in a task_rq.
+ * Used by set_protect_slice_duet() to determine the protect window.
+ */
+static inline u64 trq_min_slice(struct task_rq *trq)
+{
+	struct rb_node *root = trq->tasks_timeline.rb_root.rb_node;
+	struct sched_entity *curr = trq->curr;
+	u64 min_slice = ~0ULL;
+
+	if (curr && curr->on_rq)
+		min_slice = curr->slice;
+
+	if (root)
+		min_slice = min(min_slice, __node_2_se(root)->min_slice);
+
+	return min_slice;
+}
+
+/*
+ * Protect slice helpers for DUET — mirrors vanilla set_protect_slice()
+ * and friends, using task_rq instead of cfs_rq.
+ *
+ * vprot is set when a task becomes current. protect_slice() returns
+ * true while the task hasn't exhausted its minimum protected slice,
+ * preventing tick preemption until the task has made minimum progress.
+ */
+static inline void set_protect_slice_duet(struct task_rq *trq,
+					  struct sched_entity *se)
+{
+#ifdef CONFIG_SCHED_BORE
+	u64 slice = sysctl_sched_base_slice;
+#else
+	u64 slice = normalized_sysctl_sched_base_slice;
+#endif
+	u64 vprot = se->deadline;
+
+	if (sched_feat(RUN_TO_PARITY))
+		slice = trq_min_slice(trq);
+
+	slice = min(slice, se->slice);
+	if (slice != se->slice)
+		vprot = min_vruntime(vprot, se->vruntime + calc_delta_fair(slice, se));
+
+	se->vprot = vprot;
+}
+
+static void set_next_duet(struct rq *rq, struct task_struct *p)
+{
+	struct task_group *tg = task_group(p);
+	int cpu = cpu_of(rq);
+	struct group_entity *ge = tg->ge[cpu];
+	struct task_rq *trq = ge->my_trq;
+	struct sched_entity *se = &p->se;
+	struct group_entity *walk;
+
+	/* Walk up: commit each group_entity into its parent grq */
+	for (walk = ge; walk; walk = __ge_next_ancestor(walk))
+		grq_set_next_entity_checked(walk->grq, walk);
+
+	/* Commit task entity (dequeue from trq rb-tree, set trq->curr) */
+	trq_set_next_entity(trq, se);
+
+	/* Set slice protection window */
+	set_protect_slice_duet(trq, se);
+
+	/*
+	 * Mirror CFS set_next_entity(): set exec_start so that
+	 * update_curr_task() computes a correct delta on the next tick,
+	 * and snapshot prev_sum_exec_runtime for schedstat/hrtick.
+	 */
+	se->exec_start = rq_clock_task(rq);
+	se->prev_sum_exec_runtime = se->sum_exec_runtime;
+}
+
+/*
+ * Put back the current task/group chain.
+ * Called when the current task is being replaced.
+ *
+ * Clears stale buddy hints at each level to prevent the next pick
+ * from favouring the outgoing entity (mirrors vanilla clear_buddies).
+ */
+static void put_prev_duet(struct rq *rq)
+{
+	struct group_rq *grq = &rq->grq;
+	struct group_entity *ge;
+
+	if (!grq->curr)
+		return;
+
+	ge = grq->curr;
+
+	/* Walk down to the leaf and put_prev at each level */
+	while (ge) {
+		struct group_rq *parent_grq = ge->grq;
+
+		if (ge->my_trq) {
+			/* Leaf: put prev task, clear task buddy */
+			struct task_rq *trq = ge->my_trq;
+
+			if (trq->curr) {
+				if (trq->next == trq->curr)
+					trq->next = NULL;
+				trq_put_prev_entity(trq, trq->curr);
+			}
+		}
+
+		/* Clear group buddy */
+		if (parent_grq->next == ge)
+			parent_grq->next = NULL;
+
+		grq_put_prev_entity_checked(parent_grq, ge);
+
+		/* Move to child if intermediate */
+		if (ge->my_grq && ge->my_grq->curr)
+			ge = ge->my_grq->curr;
+		else
+			break;
+	}
+}
+
+/* PELT forward declarations for enqueue/dequeue */
+static void update_task_pelt_duet(struct task_rq *trq,
+				      struct sched_entity *se, int flags);
+/* Load balancing forward declaration */
+static inline void list_add_leaf_trq(struct task_rq *trq);
+/* Core scheduler counter sync forward declaration */
+static inline void sync_grq_to_cfs_nr(struct rq *rq);
+
+/*
+ * Update tg->load_avg from this CPU's task_rq PELT.
+ * Mirrors update_tg_load_avg() from fair.c for the DUET two-level
+ * hierarchy.  Rate-limited to at most once per ms to avoid contention
+ * on the cross-CPU atomic.
+ */
+static void update_tg_load_avg_duet(struct task_rq *trq)
+{
+	struct task_group *tg = trq->tg;
+	long delta;
+	u64 now;
+
+	if (!tg || tg == &root_task_group)
+		return;
+
+	if (!cpu_active(cpu_of(trq->rq)))
+		return;
+
+	now = sched_clock_cpu(cpu_of(trq->rq));
+	if (now - trq->last_update_tg_load_avg < NSEC_PER_MSEC)
+		return;
+
+	delta = (long)trq->avg.load_avg - (long)trq->tg_load_avg_contrib;
+	if (abs(delta) > (long)trq->tg_load_avg_contrib / 64) {
+		atomic_long_add(delta, &tg->load_avg);
+		trq->tg_load_avg_contrib = trq->avg.load_avg;
+		trq->last_update_tg_load_avg = now;
+	}
+}
+
+/*
+ * Compute cross-CPU adaptive group weight for a leaf group_entity.
+ * Mirrors calc_group_shares() from fair.c:
+ *   shares = tg->shares * local_load / tg_total_load
+ *
+ * This ensures that a desktop group with tasks on only 1 of 8 CPUs
+ * receives a proportionally higher weight on that CPU, rather than
+ * competing with build jobs at raw task-weight sums.
+ */
+static long calc_group_shares_duet(struct group_entity *ge)
+{
+	struct task_rq *trq = ge->my_trq;
+	struct task_group *tg = ge->tg;
+	long tg_weight, tg_shares, load, shares;
+
+	if (!tg || tg == &root_task_group)
+		return trq->load.weight;
+
+	tg_shares = READ_ONCE(tg->shares);
+
+	load = max(scale_load_down(trq->load.weight), trq->avg.load_avg);
+
+	tg_weight = atomic_long_read(&tg->load_avg);
+
+	/* Ensure tg_weight >= load (same correction as vanilla) */
+	tg_weight -= trq->tg_load_avg_contrib;
+	tg_weight += load;
+
+	shares = (tg_shares * load);
+	if (tg_weight)
+		shares /= tg_weight;
+
+	return clamp_t(long, shares, MIN_SHARES, tg_shares);
+}
+
+/*
+ * Sync ge->load.weight using cross-CPU adaptive weight calculation.
+ * Called after trq->load is updated by enqueue/dequeue, before the
+ * group_entity ancestor walk.  Uses calc_group_shares_duet() to
+ * distribute tg->shares proportionally across CPUs.
+ */
+static void sync_ge_task_weight(struct group_entity *ge)
+{
+	struct task_rq *trq = ge->my_trq;
+	struct group_rq *grq;
+	unsigned long new_weight, old_weight;
+
+	if (!trq || !trq->load.weight)
+		return;	/* empty trq — ge will be dequeued */
+
+	new_weight = calc_group_shares_duet(ge);
+	old_weight = ge->load.weight;
+	if (old_weight == new_weight)
+		return;
+
+	grq = ge->grq;
+	if (ge->on_rq) {
+		bool on_tree = grq->curr != ge;
+
+		if (on_tree)
+			__grq_dequeue_entity(grq, ge);
+
+		update_load_sub(&grq->load, old_weight);
+		ge->load.weight = new_weight;
+		ge->load.inv_weight = 0;
+		update_load_add(&grq->load, new_weight);
+
+		if (on_tree)
+			__grq_enqueue_entity(grq, ge);
+	} else {
+		ge->load.weight = new_weight;
+		ge->load.inv_weight = 0;
+	}
+}
+
+/* ===================================================================
+ * Two-level scheduler: enqueue/dequeue
+ * =================================================================== */
+
+/*
+ * update_entity_lag_duet — compute and save virtual lag for a task entity.
+ *
+ * vlag = V - v_i, clamped to [-limit, +limit] where
+ * limit = calc_delta_fair(max(2*slice, TICK_NSEC)).
+ *
+ * Must be called while the entity is still on_rq (before actual dequeue).
+ */
+static void update_entity_lag_duet(struct task_rq *trq,
+				   struct sched_entity *se)
+{
+	s64 vlag, limit;
+
+	WARN_ON_ONCE(!se->on_rq);
+
+	vlag = (s64)(trq_avg_vruntime(trq) - se->vruntime);
+	limit = calc_delta_fair(max_t(u64, 2 * se->slice, TICK_NSEC), se);
+#ifdef CONFIG_SCHED_BORE
+	if (static_branch_likely(&sched_bore_key))
+		limit >>= 1;
+#endif
+
+	se->vlag = clamp(vlag, -limit, limit);
+}
+
+/*
+ * Lag-preserving task vruntime placement for task_rq.
+ *
+ * On enqueue, restore the virtual lag saved at dequeue time so that the
+ * task resumes competition at a fair position.  The lag is inflated to
+ * compensate for the shift the new entity causes on the weighted average
+ * vruntime V (same algebra as vanilla place_entity).
+ */
+static void place_task_duet(struct task_rq *trq, struct sched_entity *se,
+				int flags)
+{
+	u64 vruntime = trq_avg_vruntime(trq);
+	u64 vslice = 0;
+	s64 lag = 0;
+
+	if (!se->custom_slice)
+		se->slice = sysctl_sched_base_slice;
+
+	/*
+	 * PLACE_LAG: restore saved vlag with inflation to preserve
+	 * effective lag after insertion into the weighted average.
+	 *
+	 *   vl_i = (W + w_i) * vl'_i / W
+	 *
+	 * where vl'_i is the saved vlag and W is the current total load.
+	 */
+	if (sched_feat(PLACE_LAG) && trq->nr_queued && se->vlag) {
+		struct sched_entity *curr = trq->curr;
+		unsigned long load;
+
+		lag = se->vlag;
+
+		load = trq->avg_load;
+		if (curr && curr->on_rq)
+			load += scale_load_down(curr->load.weight);
+
+		lag *= load + scale_load_down(se->load.weight);
+		if (WARN_ON_ONCE(!load))
+			load = 1;
+		lag = div_s64(lag, load);
+	}
+
+	se->vruntime = vruntime - lag;
+
+	/* Clamp: never place behind zero_vruntime */
+	if ((s64)(se->vruntime - trq->zero_vruntime) < 0)
+		se->vruntime = trq->zero_vruntime;
+
+	/* Set EEVDF deadline */
+	if (se->rel_deadline) {
+		se->deadline += se->vruntime;
+		se->rel_deadline = 0;
+		return;
+	}
+
+#ifdef CONFIG_SCHED_BORE
+	/*
+	 * BORE: futex waiters keep their existing deadline to avoid
+	 * penalizing lock-contention sleeps.
+	 */
+	if (static_branch_likely(&sched_bore_key) &&
+	    task_of(se)->bore.futex_waiting)
+		goto vslice_found;
+#endif
+	vslice = calc_delta_fair(se->slice, se);
+#ifdef CONFIG_SCHED_BORE
+	/*
+	 * BORE: halve initial vslice on wakeup to ease into competition,
+	 * matching vanilla BORE behaviour.
+	 */
+	if (static_branch_likely(&sched_bore_key))
+		vslice >>= !!(flags & (ENQUEUE_INITIAL | ENQUEUE_WAKEUP));
+	else
+#endif
+	if (sched_feat(PLACE_DEADLINE_INITIAL) &&
+	    (flags & ENQUEUE_INITIAL))
+		vslice /= 2;
+
+#ifdef CONFIG_SCHED_BORE
+vslice_found:
+#endif
+	se->deadline = se->vruntime + vslice;
+}
+
+/*
+ * Place a group_entity in its group_rq.
+ */
+static void place_ge_duet(struct group_rq *grq, struct group_entity *ge)
+{
+	if ((s64)(ge->vruntime - grq->zero_vruntime) < 0)
+		ge->vruntime = grq->zero_vruntime;
+
+	/*
+	 * Deadline propagated from children's min_deadline, not EEVDF.
+	 * Eligibility (vruntime-based) handles group fairness.
+	 */
+	ge->deadline = ge_child_min_deadline(ge);
+}
+
+/*
+ * enqueue_task_duet — enqueue a task into the two-level hierarchy.
+ *
+ * 1. Enqueue task sched_entity into leaf task_rq
+ * 2. Walk up group_entity chain, enqueuing newly-runnable groups
+ * 3. Propagate h_nr_queued/h_nr_runnable/h_nr_idle upward
+ */
+static void enqueue_task_duet(struct rq *rq, struct task_struct *p,
+				  int flags)
+{
+	struct task_group *tg = task_group(p);
+	int cpu = cpu_of(rq);
+	struct task_rq *trq = tg->trq[cpu];
+	struct group_entity *ge = tg->ge[cpu];
+	struct sched_entity *se = &p->se;
+	int h_nr_idle = task_has_idle_policy(p);
+	int rq_h_nr_queued = rq->grq.h_nr_queued;
+
+	/* Place and enqueue task into task_rq */
+	place_task_duet(trq, se, flags);
+
+	update_load_add(&trq->load, se->load.weight);
+	trq->nr_queued++;
+	__trq_enqueue_entity(trq, se);
+	se->on_rq = 1;
+	se->exec_start = rq_clock_task(rq);
+
+	/* PELT: update task avg and attach to task_rq */
+	update_task_pelt_duet(trq, se, UPDATE_TG | DO_ATTACH);
+
+	/* Add to leaf task_rq list for load balancing */
+	list_add_leaf_trq(trq);
+
+	/* Sync group weight to task weight sum before ancestor walk */
+	sync_ge_task_weight(ge);
+
+	/* NUMA and task list accounting */
+	account_numa_enqueue(rq, p);
+	list_add(&se->group_node, &rq->cfs_tasks);
+
+	/* Propagate up group hierarchy */
+	for_each_ge_ancestor(ge) {
+		struct group_rq *grq = ge->grq;
+
+		ge->h_nr_queued++;
+		ge->h_nr_runnable++;
+		ge->h_nr_idle += h_nr_idle;
+
+		if (!ge->on_rq) {
+			/* Group just became runnable — enqueue into grq */
+			place_ge_duet(grq, ge);
+			update_load_add(&grq->load, ge->load.weight);
+			__grq_enqueue_entity(grq, ge);
+			ge->on_rq = 1;
+			grq->nr_queued++;
+		} else {
+			/*
+			 * Group already on_rq: new task may have a smaller
+			 * deadline than what's currently propagated.
+			 */
+			u64 new_dl = ge_child_min_deadline(ge);
+
+			if ((s64)(new_dl - ge->deadline) < 0) {
+				if (grq->curr == ge) {
+					ge->deadline = new_dl;
+				} else {
+					__grq_dequeue_entity(grq, ge);
+					ge->deadline = new_dl;
+					__grq_enqueue_entity(grq, ge);
+				}
+			}
+		}
+
+		grq->h_nr_queued++;
+		grq->h_nr_runnable++;
+		grq->h_nr_idle += h_nr_idle;
+	}
+
+	/* Start fair server if CFS just became runnable */
+	if (!rq_h_nr_queued && rq->grq.h_nr_queued) {
+		if (!rq->nr_running)
+			dl_server_update_idle_time(rq, rq->curr);
+		dl_server_start(&rq->fair_server);
+	}
+
+	sync_grq_to_cfs_nr(rq);
+	add_nr_running(rq, 1);
+	hrtick_update(rq);
+}
+
+/*
+ * dequeue_task_duet — dequeue a task from the two-level hierarchy.
+ *
+ * 1. Dequeue task sched_entity from leaf task_rq
+ * 2. Walk up group_entity chain, dequeuing newly-empty groups
+ * 3. Propagate h_nr_queued/h_nr_runnable/h_nr_idle downward
+ */
+static bool dequeue_task_duet(struct rq *rq, struct task_struct *p,
+				  int flags)
+{
+	struct task_group *tg = task_group(p);
+	int cpu = cpu_of(rq);
+	struct task_rq *trq = tg->trq[cpu];
+	struct group_entity *ge = tg->ge[cpu];
+	struct sched_entity *se = &p->se;
+	int h_nr_idle = task_has_idle_policy(p);
+
+	/* Update current task's vruntime if it's running */
+	if (trq->curr == se)
+		update_curr_task(trq, rq_clock_task(rq));
+
+#ifdef CONFIG_SCHED_BORE
+	/* BORE: reset burst tracking on sleep */
+	if ((flags & DEQUEUE_SLEEP) &&
+	    static_branch_likely(&sched_bore_key))
+		restart_burst_bore(p);
+#endif
+
+	/*
+	 * Save virtual lag before leaving the runqueue.
+	 * On next enqueue, place_task_duet() will restore this lag
+	 * so the task resumes at a fair vruntime position.
+	 */
+	update_entity_lag_duet(trq, se);
+	if (sched_feat(PLACE_REL_DEADLINE) && !(flags & DEQUEUE_SLEEP)) {
+		se->deadline -= se->vruntime;
+		se->rel_deadline = 1;
+	}
+
+	/* Dequeue from task_rq */
+	update_load_sub(&trq->load, se->load.weight);
+	if (se != trq->curr)
+		__trq_dequeue_entity(trq, se);
+	else
+		trq->curr = NULL;
+	se->on_rq = 0;
+	trq->nr_queued--;
+
+	account_numa_dequeue(rq, p);
+	list_del_init(&se->group_node);
+
+	/* PELT: update task avg and detach from task_rq */
+	update_task_pelt_duet(trq, se, UPDATE_TG | DO_DETACH);
+
+	trq_update_zero_vruntime(trq);
+
+	/* Sync group weight to task weight sum before ancestor walk */
+	sync_ge_task_weight(ge);
+
+	/* Propagate up group hierarchy */
+	for_each_ge_ancestor(ge) {
+		struct group_rq *grq = ge->grq;
+
+		ge->h_nr_queued--;
+		ge->h_nr_runnable--;
+		ge->h_nr_idle -= h_nr_idle;
+
+		grq->h_nr_queued--;
+		grq->h_nr_runnable--;
+		grq->h_nr_idle -= h_nr_idle;
+
+		/* If group became empty, dequeue it from parent grq */
+		if (ge->h_nr_queued == 0 && ge->on_rq) {
+			if (grq->curr == ge)
+				grq->curr = NULL;
+			else
+				__grq_dequeue_entity(grq, ge);
+			update_load_sub(&grq->load, ge->load.weight);
+			ge->on_rq = 0;
+			grq->nr_queued--;
+		} else if (ge->on_rq) {
+			/*
+			 * Group still has tasks: dequeued task may have
+			 * had the smallest deadline.  Recompute.
+			 */
+			u64 new_dl = ge_child_min_deadline(ge);
+
+			if (ge->deadline != new_dl) {
+				if (grq->curr == ge) {
+					ge->deadline = new_dl;
+				} else {
+					__grq_dequeue_entity(grq, ge);
+					ge->deadline = new_dl;
+					__grq_enqueue_entity(grq, ge);
+				}
+			}
+		}
+	}
+
+	sync_grq_to_cfs_nr(rq);
+	sub_nr_running(rq, 1);
+	hrtick_update(rq);
+	return true;
+}
+
+/* ===================================================================
+ * Two-level scheduler: upward runtime propagation
+ *
+ * Replaces calc_group_shares() + update_cfs_group() entirely.
+ * Group weight = tg->shares (fixed, no dynamic recalculation).
+ * delta_exec from task → ge.consumed → vruntime at each level.
+ * =================================================================== */
+
+#ifdef CONFIG_CFS_BANDWIDTH
+static void account_grq_runtime(struct group_rq *grq, u64 delta_exec);
+static bool check_grq_runtime(struct group_rq *grq);
+#endif
+
+/* PELT forward declarations and inline helpers */
+static inline u64 trq_clock_pelt(struct task_rq *trq)
+{
+	return rq_clock_pelt(trq->rq);
+}
+static inline u64 grq_clock_pelt(struct group_rq *grq)
+{
+	return rq_clock_pelt(grq->rq);
+}
+static void propagate_ge_pelt_duet(struct group_entity *ge);
+static void sync_grq_to_cfs_avg(struct rq *rq);
+
+/*
+ * Feed consumed execution time from a task_rq up through the group
+ * hierarchy. At each level, the delta is accumulated in the group
+ * entity's consumed field. update_curr_group() then converts the
+ * accumulated consumed time into vruntime changes.
+ */
+static void feed_consumed_upward(struct task_rq *trq, u64 delta_exec)
+{
+	struct group_entity *ge = trq->owner;
+
+	/*
+	 * Re-evaluate cross-CPU tg->load_avg and adaptive group weight
+	 * on each tick.  update_tg_load_avg_duet() is rate-limited to
+	 * once per ms internally, so calling it here is safe.
+	 */
+	update_tg_load_avg_duet(trq);
+	sync_ge_task_weight(ge);
+
+	for_each_ge_ancestor(ge) {
+		struct group_rq *grq = ge->grq;
+
+		ge->consumed += delta_exec;
+		update_curr_group(grq);
+
+		/* PELT: propagate child avg to group_entity, update group_rq */
+		__update_load_avg_grq(grq_clock_pelt(grq), grq);
+		propagate_ge_pelt_duet(ge);
+
+#ifdef CONFIG_CFS_BANDWIDTH
+		/* Account bandwidth runtime at this group level */
+		if (ge->my_trq || ge->my_grq) {
+			struct group_rq *child_grq = ge->my_grq;
+
+			/*
+			 * For leaf groups (my_trq), we account against
+			 * the parent group_rq's bandwidth.
+			 * For intermediate groups (my_grq), account against
+			 * the child group_rq's bandwidth.
+			 */
+			if (child_grq) {
+				account_grq_runtime(child_grq, delta_exec);
+				if (check_grq_runtime(child_grq))
+					break; /* throttled, stop propagation */
+			}
+		}
+#endif
+	}
+
+	/* Sync root group_rq PELT to rq->cfs.avg for EAS/schedutil */
+	sync_grq_to_cfs_avg(trq->rq);
+}
+
+/*
+ * task_tick_duet — periodic tick for two-level scheduler.
+ *
+ * 1. Update running task's vruntime/deadline
+ * 2. Propagate delta up through group hierarchy
+ * 3. Check for preemption (deadline or protect_slice expiry)
+ */
+static void task_tick_duet(struct rq *rq, struct task_struct *p,
+			       int queued)
+{
+	struct task_group *tg = task_group(p);
+	int cpu = cpu_of(rq);
+	struct task_rq *trq = tg->trq[cpu];
+	struct sched_entity *curr = trq->curr;
+	u64 delta_exec, old_deadline = 0;
+	bool resched;
+
+	if (curr)
+		old_deadline = curr->deadline;
+
+	delta_exec = update_curr_task(trq, rq_clock_task(rq));
+	if (!delta_exec)
+		return;
+
+	/* Feed consumed runtime up the hierarchy */
+	feed_consumed_upward(trq, delta_exec);
+
+	/* Detect deadline crossing (slice fully consumed) */
+	curr = trq->curr;
+	resched = curr && curr->deadline != old_deadline;
+
+	/* Preemption: reschedule if slice consumed or protection expired */
+	if (trq->nr_queued > 1 && curr) {
+		if (resched || !protect_slice(curr)) {
+			resched_curr_lazy(rq);
+			trq->next = NULL;
+		}
+	}
+
+	/*
+	 * Group-level preemption: check if the current group_entity has
+	 * lost eligibility or has a later deadline than an eligible sibling
+	 * at each ancestor level.  Without this, a group with many runnable
+	 * tasks (e.g. kernel build) monopolises the CPU because task_tick
+	 * only checks within the leaf task_rq.
+	 */
+	if (!test_tsk_need_resched(rq->curr)) {
+		struct group_entity *ge = tg->ge[cpu];
+
+		for_each_ge_ancestor(ge) {
+			struct group_rq *grq = ge->grq;
+			struct wavl_node *left;
+			struct group_entity *left_ge;
+
+			if (grq->nr_queued <= 1 || !grq->curr)
+				continue;
+
+			/* Eligibility lost: must reschedule */
+			if (!grq_entity_eligible(grq, grq->curr)) {
+				resched_curr_lazy(rq);
+				break;
+			}
+
+			/*
+			 * Deadline inversion: an eligible sibling has an
+			 * earlier deadline than the current group_entity.
+			 * This ensures a desktop group (short deadline)
+			 * preempts a build group (long deadline).
+			 */
+			left = wavl_first_cached(&grq->groups_timeline);
+			if (!left)
+				continue;
+			left_ge = __grq_node_2_ge(left);
+			if (grq_entity_eligible(grq, left_ge) &&
+			    ge_before(left_ge, grq->curr)) {
+				resched_curr_lazy(rq);
+				break;
+			}
+		}
+	}
+}
+
+/* ===================================================================
+ * Two-level scheduler: bandwidth throttling
+ *
+ * Throttling a group_entity = dequeue from parent group_rq.
+ * The entire subtree becomes unreachable in a single operation,
+ * replacing walk_tg_tree_from() + per-cfs_rq throttle propagation.
+ * =================================================================== */
+
+#ifdef CONFIG_CFS_BANDWIDTH
+
+/*
+ * Assign runtime to a group_rq from its bandwidth pool.
+ * Returns true if runtime is now positive.
+ */
+static bool assign_group_rq_runtime(struct group_rq *grq)
+{
+	struct cfs_bandwidth *cfs_b;
+	u64 amount, min_amount;
+
+	if (!grq->tg)
+		return true;	/* root has unlimited runtime */
+
+	cfs_b = tg_cfs_bandwidth(grq->tg);
+
+	raw_spin_lock(&cfs_b->lock);
+
+	if (cfs_b->quota == RUNTIME_INF) {
+		grq->runtime_remaining = 1;
+		raw_spin_unlock(&cfs_b->lock);
+		return true;
+	}
+
+	min_amount = sched_cfs_bandwidth_slice() -
+		     grq->runtime_remaining;
+	amount = min((u64)cfs_b->runtime, min_amount);
+	cfs_b->runtime -= amount;
+	grq->runtime_remaining += amount;
+
+	if (cfs_b->runtime <= 0)
+		start_cfs_bandwidth(cfs_b);
+
+	raw_spin_unlock(&cfs_b->lock);
+
+	return grq->runtime_remaining > 0;
+}
+
+/*
+ * Throttle a group_entity — dequeue from parent group_rq.
+ * The subtree beneath ge becomes completely unreachable.
+ * No walk_tg_tree_from() needed.
+ */
+static void throttle_group_entity(struct group_entity *ge)
+{
+	struct group_rq *grq = ge->grq;
+	struct group_entity *parent;
+	unsigned int lost_queued, lost_runnable, lost_idle;
+
+	if (ge->throttled)
+		return;
+
+	ge->throttled = true;
+
+	/* Dequeue from parent group_rq */
+	if (ge->on_rq) {
+		if (grq->curr == ge)
+			grq->curr = NULL;
+		else
+			__grq_dequeue_entity(grq, ge);
+		update_load_sub(&grq->load, ge->load.weight);
+		ge->on_rq = 0;
+		grq->nr_queued--;
+	}
+
+	/* Propagate h_nr loss up the hierarchy */
+	lost_queued = ge->h_nr_queued;
+	lost_runnable = ge->h_nr_runnable;
+	lost_idle = ge->h_nr_idle;
+
+	grq->h_nr_queued -= lost_queued;
+	grq->h_nr_runnable -= lost_runnable;
+	grq->h_nr_idle -= lost_idle;
+
+	for (parent = ge->parent; parent; parent = parent->parent) {
+		struct group_rq *pgrq = parent->grq;
+
+		/* Stop if parent is in the same grq (flat hierarchy) */
+		if (pgrq == grq)
+			break;
+
+		parent->h_nr_queued -= lost_queued;
+		parent->h_nr_runnable -= lost_runnable;
+		parent->h_nr_idle -= lost_idle;
+
+		pgrq->h_nr_queued -= lost_queued;
+		pgrq->h_nr_runnable -= lost_runnable;
+		pgrq->h_nr_idle -= lost_idle;
+
+		/* If parent became empty, dequeue it too */
+		if (parent->h_nr_queued == 0 && parent->on_rq) {
+			if (pgrq->curr == parent)
+				pgrq->curr = NULL;
+			else
+				__grq_dequeue_entity(pgrq, parent);
+			update_load_sub(&pgrq->load, parent->load.weight);
+			parent->on_rq = 0;
+			pgrq->nr_queued--;
+		}
+	}
+}
+
+/*
+ * Account runtime consumption for a group_rq.
+ * Called from feed_consumed_upward when delta flows through.
+ */
+static void account_grq_runtime(struct group_rq *grq, u64 delta_exec)
+{
+	if (!grq->runtime_enabled)
+		return;
+
+	grq->runtime_remaining -= (s64)delta_exec;
+}
+
+/*
+ * Check if a group_rq has exceeded its bandwidth.
+ * If so, throttle the owning group_entity.
+ */
+static bool check_grq_runtime(struct group_rq *grq)
+{
+	struct group_entity *ge;
+
+	if (!grq->runtime_enabled)
+		return false;
+
+	if (grq->runtime_remaining > 0)
+		return false;
+
+	/* Try to assign more runtime from the bandwidth pool */
+	if (assign_group_rq_runtime(grq))
+		return false;
+
+	/* No runtime available — find the group_entity that owns this grq */
+	if (!grq->tg)
+		return false;
+
+	ge = grq->tg->ge ? grq->tg->ge[smp_processor_id()] : NULL;
+	if (!ge)
+		return false;
+
+	throttle_group_entity(ge);
+	return true;
+}
+
+#endif /* CONFIG_CFS_BANDWIDTH */
+
+/* ===================================================================
+ * Two-level scheduler: PELT (Per-Entity Load Tracking)
+ *
+ * Task-level PELT tracks per-task and per-task_rq load averages.
+ * Group-level PELT propagates child averages up through group_entity
+ * to parent group_rq. No entity_is_task() checks — type safety is
+ * structural.
+ *
+ * Root group_rq PELT is mirrored to rq->cfs.avg so that existing
+ * consumers (EAS, schedutil, load balancing) see correct data.
+ * =================================================================== */
+
+/*
+ * Attach a task entity's PELT contribution to its task_rq.
+ * Called when a task is first enqueued (DO_ATTACH).
+ * Aligns PELT window with task_rq, then adds contribution.
+ */
+static void attach_task_pelt_duet(struct task_rq *trq,
+				      struct sched_entity *se)
+{
+	u32 divider = get_pelt_divider(&trq->avg);
+
+	/* Align PELT window */
+	se->avg.last_update_time = trq->avg.last_update_time;
+	se->avg.period_contrib = trq->avg.period_contrib;
+
+	/* Recompute sums from averages using new window */
+	se->avg.util_sum = se->avg.util_avg * divider;
+	se->avg.runnable_sum = se->avg.runnable_avg * divider;
+
+	if (se_weight(se)) {
+		se->avg.load_sum = div_u64(
+			(u64)se->avg.load_avg * divider, se_weight(se));
+	} else {
+		se->avg.load_sum = 1;
+	}
+
+	/* Add to task_rq aggregate */
+	trq->avg.load_avg += se->avg.load_avg;
+	trq->avg.load_sum += se_weight(se) * se->avg.load_sum;
+	trq->avg.util_avg += se->avg.util_avg;
+	trq->avg.util_sum += se->avg.util_sum;
+	trq->avg.runnable_avg += se->avg.runnable_avg;
+	trq->avg.runnable_sum += se->avg.runnable_sum;
+}
+
+/*
+ * Detach a task entity's PELT contribution from its task_rq.
+ * Called when a task is dequeued (DO_DETACH).
+ */
+static void detach_task_pelt_duet(struct task_rq *trq,
+				      struct sched_entity *se)
+{
+	sub_positive(&trq->avg.load_avg, se->avg.load_avg);
+	sub_positive(&trq->avg.load_sum,
+		     (unsigned long)(se_weight(se) * se->avg.load_sum));
+	trq->avg.load_sum = max_t(u32, trq->avg.load_sum,
+				  trq->avg.load_avg * PELT_MIN_DIVIDER);
+
+	sub_positive(&trq->avg.util_avg, se->avg.util_avg);
+	sub_positive(&trq->avg.util_sum, se->avg.util_sum);
+	trq->avg.util_sum = max_t(u32, trq->avg.util_sum,
+				  trq->avg.util_avg * PELT_MIN_DIVIDER);
+
+	sub_positive(&trq->avg.runnable_avg, se->avg.runnable_avg);
+	sub_positive(&trq->avg.runnable_sum, se->avg.runnable_sum);
+	trq->avg.runnable_sum = max_t(u32, trq->avg.runnable_sum,
+				      trq->avg.runnable_avg * PELT_MIN_DIVIDER);
+}
+
+/*
+ * Update PELT for a task entity in its task_rq, and update task_rq aggregate.
+ * Analog of update_load_avg() but for the two-level task_rq path.
+ */
+static void update_task_pelt_duet(struct task_rq *trq,
+				      struct sched_entity *se, int flags)
+{
+	u64 now = trq_clock_pelt(trq);
+
+	if (se->avg.last_update_time && !(flags & SKIP_AGE_LOAD))
+		__update_load_avg_trq_se(now, trq, se);
+
+	__update_load_avg_trq(now, trq);
+
+	if (!se->avg.last_update_time && (flags & DO_ATTACH)) {
+		attach_task_pelt_duet(trq, se);
+	} else if (flags & DO_DETACH) {
+		detach_task_pelt_duet(trq, se);
+	}
+
+	/* Update cross-CPU tg->load_avg for adaptive group weight */
+	if (flags & UPDATE_TG)
+		update_tg_load_avg_duet(trq);
+}
+
+/*
+ * Propagate PELT from a group_entity's child (task_rq or group_rq)
+ * to the group_entity itself, then update the parent group_rq aggregate.
+ *
+ * Replaces propagate_entity_load_avg() + update_tg_cfs_util/runnable/load.
+ * No entity_is_task() check — group_entity is always a group by type.
+ */
+static void propagate_ge_pelt_duet(struct group_entity *ge)
+{
+	struct group_rq *parent_grq = ge->grq;
+	struct sched_avg *child_avg;
+	u32 divider;
+	long delta;
+
+	if (!parent_grq)
+		return;
+
+	/* Get the child's aggregate PELT */
+	if (ge->my_trq)
+		child_avg = &ge->my_trq->avg;
+	else if (ge->my_grq)
+		child_avg = &ge->my_grq->avg;
+	else
+		return;
+
+	divider = get_pelt_divider(&parent_grq->avg);
+	if (!divider)
+		return;
+
+	/* Propagate util_avg: ge mirrors child */
+	delta = (long)child_avg->util_avg - (long)ge->avg.util_avg;
+	if (delta) {
+		ge->avg.util_avg = child_avg->util_avg;
+		ge->avg.util_sum = ge->avg.util_avg * divider;
+		add_positive(&parent_grq->avg.util_avg, delta);
+		parent_grq->avg.util_sum =
+			parent_grq->avg.util_avg * divider;
+	}
+
+	/* Propagate runnable_avg: ge mirrors child */
+	delta = (long)child_avg->runnable_avg - (long)ge->avg.runnable_avg;
+	if (delta) {
+		ge->avg.runnable_avg = child_avg->runnable_avg;
+		ge->avg.runnable_sum = ge->avg.runnable_avg * divider;
+		add_positive(&parent_grq->avg.runnable_avg, delta);
+		parent_grq->avg.runnable_sum =
+			parent_grq->avg.runnable_avg * divider;
+	}
+
+	/* Propagate load_avg: ge_weight * runnable_proportion */
+	{
+		unsigned long ge_w = scale_load_down(ge->load.weight);
+		unsigned long new_load_avg;
+		long load_delta;
+
+		if (ge_w && child_avg->runnable_avg)
+			new_load_avg = min_t(unsigned long,
+				ge_w * child_avg->runnable_avg
+					/ SCHED_CAPACITY_SCALE,
+				ge_w);
+		else
+			new_load_avg = 0;
+
+		load_delta = (long)new_load_avg - (long)ge->avg.load_avg;
+		if (load_delta) {
+			ge->avg.load_avg = new_load_avg;
+			ge->avg.load_sum = div_u64(
+				(u64)ge->avg.load_avg * divider,
+				ge_w ? ge_w : 1);
+			add_positive(&parent_grq->avg.load_avg, load_delta);
+			parent_grq->avg.load_sum = max_t(u32,
+				parent_grq->avg.load_sum,
+				parent_grq->avg.load_avg * PELT_MIN_DIVIDER);
+		}
+	}
+}
+
+/*
+ * Sync root group_rq PELT data to rq->cfs.avg.
+ * This ensures EAS, schedutil, and other PELT consumers see updated data
+ * without modification. The root group_rq aggregates all CFS load.
+ */
+static void sync_grq_to_cfs_avg(struct rq *rq)
+{
+	struct sched_avg *src = &rq->grq.avg;
+	struct sched_avg *dst = &rq->cfs.avg;
+
+	dst->util_avg = src->util_avg;
+	dst->util_sum = src->util_sum;
+	dst->runnable_avg = src->runnable_avg;
+	dst->runnable_sum = src->runnable_sum;
+	dst->load_avg = src->load_avg;
+	dst->load_sum = src->load_sum;
+	dst->last_update_time = src->last_update_time;
+	dst->period_contrib = src->period_contrib;
+}
+
+/*
+ * Sync root group_rq task counts to rq->cfs so that core scheduler
+ * paths (pick_next_task fast path, ttwu preemption, load balancing)
+ * see correct values without modification.
+ */
+static inline void sync_grq_to_cfs_nr(struct rq *rq)
+{
+	rq->cfs.nr_queued     = rq->grq.h_nr_queued;
+	rq->cfs.h_nr_queued   = rq->grq.h_nr_queued;
+	rq->cfs.h_nr_runnable = rq->grq.h_nr_runnable;
+	rq->cfs.h_nr_idle     = rq->grq.h_nr_idle;
+}
+
+/* ===================================================================
+ * Two-level scheduler: load balancing support
+ *
+ * Replaces leaf_cfs_rq_list with leaf_trq_list for blocked updates.
+ * Replaces update_cfs_rq_h_load / task_h_load with group_entity
+ * chain walk — no for_each_sched_entity or entity_is_task needed.
+ * =================================================================== */
+
+static inline void list_add_leaf_trq(struct task_rq *trq)
+{
+	struct rq *rq = trq->rq;
+
+	if (trq->on_list)
+		return;
+
+	list_add_rcu(&trq->leaf_trq_list, &rq->leaf_trq_list);
+	trq->on_list = 1;
+}
+
+static inline void list_del_leaf_trq(struct task_rq *trq)
+{
+	if (trq->on_list) {
+		list_del_rcu(&trq->leaf_trq_list);
+		trq->on_list = 0;
+	}
+}
+
+#define for_each_leaf_trq_safe(rq, trq, pos)				\
+	list_for_each_entry_safe(trq, pos, &rq->leaf_trq_list,		\
+				 leaf_trq_list)
+
+static inline bool trq_has_blocked(struct task_rq *trq)
+{
+	return !load_avg_is_decayed(&trq->avg);
+}
+
+static inline bool trq_is_decayed(struct task_rq *trq)
+{
+	return !trq->nr_queued && trq_has_blocked(trq) == false;
+}
+
+/*
+ * Update blocked PELT averages for all leaf task_rqs.
+ * Two-level replacement for __update_blocked_fair().
+ */
+static bool __update_blocked_fair_duet(struct rq *rq, bool *done)
+{
+	struct task_rq *trq, *pos;
+	bool decayed = false;
+	u64 now = rq_clock_pelt(rq);
+
+	for_each_leaf_trq_safe(rq, trq, pos) {
+		/* Update task_rq aggregate */
+		if (__update_load_avg_trq(now, trq))
+			decayed = true;
+
+		/* Propagate to owning group_entity */
+		if (trq->owner)
+			propagate_ge_pelt_duet(trq->owner);
+
+		/* Remove fully decayed task_rqs from the list */
+		if (trq_is_decayed(trq))
+			list_del_leaf_trq(trq);
+
+		if (trq_has_blocked(trq))
+			*done = false;
+	}
+
+	/* Update root group_rq */
+	if (__update_load_avg_grq(now, &rq->grq))
+		decayed = true;
+
+	if (decayed)
+		sync_grq_to_cfs_avg(rq);
+
+	return decayed;
+}
+
+/*
+ * Compute hierarchical load for a task_rq.
+ * Walks up the group_entity->parent chain, computing the load fraction
+ * at each level. No for_each_sched_entity or h_load_next chain needed.
+ *
+ * h_load = root_load * (ge_load/grq_load) at each level
+ */
+static void update_trq_h_load(struct task_rq *trq)
+{
+	struct group_entity *ge = trq->owner;
+	unsigned long now = jiffies;
+	unsigned long h_load;
+
+	if (trq->last_h_load_update == now)
+		return;
+
+	/* Start from root group_rq load */
+	h_load = READ_ONCE(trq->rq->grq.avg.load_avg);
+
+	/* Walk down from root to leaf, scaling at each level */
+	/* We collect ancestor chain first, then compute top-down */
+	{
+		struct group_entity *chain[16]; /* max depth 16 */
+		int depth = 0;
+		struct group_entity *walk;
+
+		for (walk = ge; walk && depth < 16; walk = __ge_next_ancestor(walk)) {
+			chain[depth++] = walk;
+		}
+
+		/* Now compute top-down: from chain[depth-1] (nearest root) */
+		while (depth > 0) {
+			struct group_entity *cur = chain[--depth];
+			struct group_rq *grq = cur->grq;
+			unsigned long grq_load;
+
+			if (!grq)
+				break;
+
+			grq_load = READ_ONCE(grq->avg.load_avg) + 1;
+			h_load = div64_ul(
+				(u64)h_load * cur->avg.load_avg, grq_load);
+		}
+	}
+
+	trq->h_load = h_load;
+	trq->last_h_load_update = now;
+}
+
+/*
+ * Task hierarchical load for the two-level scheduler.
+ * Replaces task_h_load() — no entity_is_task or cfs_rq needed.
+ */
+static unsigned long task_h_load_duet(struct task_struct *p)
+{
+	struct task_group *tg = task_group(p);
+	int cpu = task_cpu(p);
+	struct task_rq *trq = tg->trq[cpu];
+	unsigned long trq_load;
+
+	update_trq_h_load(trq);
+
+	trq_load = READ_ONCE(trq->avg.load_avg) + 1;
+	return div64_ul(p->se.avg.load_avg * trq->h_load, trq_load);
+}
+
+/* ===================================================================
+ * Two-level scheduler: preemption wakeup check
+ *
+ * Same-group comparison: direct EEVDF comparison in task_rq.
+ * Cross-group comparison: walk up group_entity->parent chains to
+ * find common ancestor, then compare group_entity deadlines.
+ * No find_matching_se() or entity_is_task() needed.
+ * =================================================================== */
+
+static void check_preempt_wakeup_duet(struct rq *rq, struct task_struct *p,
+					   int wake_flags)
+{
+	struct task_struct *donor = rq->donor;
+	struct sched_entity *se = &donor->se, *pse = &p->se;
+	struct task_group *tg_curr = task_group(donor);
+	struct task_group *tg_wake = task_group(p);
+	int cpu = cpu_of(rq);
+	bool do_preempt_short = false;
+
+	if (task_is_throttled(p))
+		return;
+
+	if (test_tsk_need_resched(rq->curr))
+		return;
+
+	if (!sched_feat(WAKEUP_PREEMPTION))
+		return;
+
+	/* NEXT_BUDDY: hint the waking task for immediate pick */
+	if (sched_feat(NEXT_BUDDY) && !(wake_flags & WF_FORK) &&
+	    !pse->sched_delayed) {
+		struct task_rq *trq = tg_wake->trq[cpu];
+
+		trq->next = pse;
+
+		/* Also hint the group level for cross-group wakeups */
+		if (tg_curr != tg_wake) {
+			struct group_entity *ge = tg_wake->ge[cpu];
+
+			if (ge && ge->on_rq)
+				ge->grq->next = ge;
+		}
+	}
+
+	/* Same group: both tasks are in the same task_rq */
+	if (tg_curr == tg_wake) {
+		struct task_rq *trq = tg_curr->trq[cpu];
+
+		/* Update curr's vruntime before comparison */
+		update_curr_task(trq, rq_clock_task(rq));
+
+		/*
+		 * PREEMPT_SHORT: a waking task with a shorter slice can
+		 * override the current task's slice protection.
+		 */
+		do_preempt_short = sched_feat(PREEMPT_SHORT) &&
+				   (pse->slice < se->slice);
+
+		/* EEVDF: preempt if waking task is the best pick */
+		if (__trq_pick_eevdf(trq) == pse)
+			goto preempt;
+
+#ifdef CONFIG_SCHED_BORE
+		/* BORE: preempt lower-penalty task */
+		if (static_branch_likely(&sched_bore_key) &&
+		    sched_feat(PREEMPT_SHORT_BORE) &&
+		    task_of(pse)->bore.penalty <
+		    task_of(se)->bore.penalty) {
+			do_preempt_short = true;
+			goto preempt;
+		}
+#endif
+
+		if (sched_feat(RUN_TO_PARITY) && do_preempt_short) {
+			u64 min_slice = trq_min_slice(trq);
+
+			se->vprot = min_vruntime(se->vprot,
+				se->vruntime + calc_delta_fair(min_slice, se));
+		}
+		return;
+	}
+
+	/* Different groups: compare at common group ancestor */
+	{
+		struct group_entity *ge_curr = tg_curr->ge[cpu];
+		struct group_entity *ge_wake = tg_wake->ge[cpu];
+
+		if (!ge_curr || !ge_wake)
+			return;
+
+		/* Walk up to same depth */
+		while (ge_curr->depth > ge_wake->depth)
+			ge_curr = ge_curr->parent;
+		while (ge_wake->depth > ge_curr->depth)
+			ge_wake = ge_wake->parent;
+
+		/* Walk up together until same parent group_rq */
+		while (ge_curr && ge_wake && ge_curr->grq != ge_wake->grq) {
+			ge_curr = ge_curr->parent;
+			ge_wake = ge_wake->parent;
+		}
+
+		if (ge_curr && ge_wake && ge_before(ge_wake, ge_curr))
+			goto preempt;
+	}
+
+	return;
+
+preempt:
+	if (do_preempt_short)
+		cancel_protect_slice(se);
+
+	resched_curr_lazy(rq);
+}
+
+/*
+ * Handle task group change for duet.
+ *
+ * Called from sched_move_task() between dequeue and enqueue.
+ * The dequeue/enqueue cycle already handles:
+ *   - vlag save/restore via update_entity_lag_duet / place_task_duet
+ *   - PELT detach/attach via update_task_pelt_duet (DO_DETACH/DO_ATTACH)
+ *   - rel_deadline preservation via PLACE_REL_DEADLINE
+ *
+ * Here we reset the PELT window so the entity re-attaches cleanly
+ * to the new task_rq, and update the legacy cfs_rq pointer.
+ */
+static void task_change_group_duet(struct task_struct *p)
+{
+	p->se.avg.last_update_time = 0;
+	set_task_rq(p, task_cpu(p));
+}
+
+/*
+ * yield_task_duet — voluntarily give up the CPU.
+ *
+ * Forfeit the remaining vruntime by advancing to the current deadline,
+ * then set a new deadline one full slice ahead.  This pushes the task
+ * to the back of the EEVDF queue.  Only acts when the entity is
+ * eligible to avoid runaway vruntime in core-scheduling loops.
+ */
+static void yield_task_duet(struct rq *rq)
+{
+	struct task_struct *curr = rq->donor;
+	struct task_group *tg = task_group(curr);
+	int cpu = cpu_of(rq);
+	struct task_rq *trq = tg->trq[cpu];
+	struct sched_entity *se = &curr->se;
+
+#ifdef CONFIG_SCHED_BORE
+	update_rq_clock(rq);
+	update_curr_task(trq, rq_clock_task(rq));
+	restart_burst_rescale_deadline_bore(curr);
+	if (unlikely(rq->nr_running == 1))
+		return;
+	trq->next = NULL;
+#else
+	if (unlikely(rq->nr_running == 1))
+		return;
+	trq->next = NULL;
+	update_rq_clock(rq);
+	update_curr_task(trq, rq_clock_task(rq));
+#endif
+
+	rq_clock_skip_update(rq);
+
+	if (trq_entity_eligible(trq, se)) {
+		se->vruntime = se->deadline;
+		se->deadline += calc_delta_fair(se->slice, se);
+	}
+}
+
+/*
+ * yield_to_task_duet — yield the current task in favor of a specific task.
+ */
+static bool yield_to_task_duet(struct rq *rq, struct task_struct *p)
+{
+	struct sched_entity *se = &p->se;
+
+	if (!se->on_rq)
+		return false;
+
+	/* Hint the target task for immediate pick */
+	{
+		struct task_group *tg = task_group(p);
+		struct task_rq *trq = tg->trq[cpu_of(rq)];
+
+		trq->next = se;
+	}
+
+	yield_task_duet(rq);
+	return true;
+}
+
+void __init sched_init_duet(void)
+{
+	printk(KERN_INFO "%s %s by %s\n",
+		SCHED_DUET_PROGNAME, SCHED_DUET_VERSION, SCHED_DUET_AUTHOR);
+}
+
+#endif /* CONFIG_SCHED_DUET */
