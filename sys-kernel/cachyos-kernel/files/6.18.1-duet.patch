+/*
+ * Two-level scheduler structures.
+ *
+ * The core idea: group entities and task entities are completely separate
+ * types that never share the same runqueue. This eliminates all
+ * entity_is_task() runtime checks and for_each_sched_entity() mixed walks.
+ *
+ *   group_rq  contains only  group_entity  (groups compete with groups)
+ *   task_rq   contains only  sched_entity  (tasks compete with tasks)
+ *
+ * Hierarchy: root group_rq → group_entity → child group_rq → ... → task_rq
+ */
+
+struct group_entity;
+struct group_rq;
+struct task_rq;
+
+/*
+ * Group entity: represents a task_group at one level of the cgroup hierarchy.
+ * Lives exclusively in a group_rq. Never appears in a task_rq.
+ */
+struct group_entity {
+	/* EEVDF scheduling fields */
+	struct load_weight	load;
+	struct wavl_node	run_node;
+	u64			deadline;
+	u64			min_vruntime;
+	u64			min_slice;
+
+	struct list_head	group_node;
+	unsigned char		on_rq;
+	unsigned char		sched_delayed;
+	unsigned char		rel_deadline;
+
+	u64			exec_start;
+	u64			sum_exec_runtime;
+	u64			vruntime;
+	union {
+		s64		vlag;
+		u64		vprot;
+	};
+	u64			slice;
+
+	/* Group hierarchy */
+	int			depth;
+	struct group_entity	*parent;	/* parent in group hierarchy */
+	struct group_rq		*grq;		/* group_rq this entity is queued on */
+
+	/* Child ownership: exactly one of these is non-NULL */
+	struct group_rq		*my_grq;	/* child group_rq (intermediate) */
+	struct task_rq		*my_trq;	/* child task_rq (leaf) */
+
+	/* Consumed execution time from children, for upward vruntime feed */
+	u64			consumed;
+
+	/* Hierarchical count of runnable tasks (all descendants) */
+	unsigned int		h_nr_queued;
+	unsigned int		h_nr_runnable;
+	unsigned int		h_nr_idle;
+
+	/* Bandwidth throttle state */
+	bool			throttled;
+
+	/* Back-pointer to owning task_group */
+	struct task_group	*tg;
+
+	/* PELT load tracking */
+	struct sched_avg	avg;
+	unsigned long		runnable_weight;
+};
+
+/*
+ * Group runqueue: contains only group_entity instances.
+ * One per intermediate cgroup level per CPU. The root level
+ * has one embedded in struct rq.
