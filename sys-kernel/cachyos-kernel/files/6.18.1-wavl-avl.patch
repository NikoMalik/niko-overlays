+++ b/include/linux/wavl_types.h
@@ -0,0 +1,33 @@
+/* SPDX-License-Identifier: GPL-2.0-or-later */
+#ifndef _LINUX_WAVL_TYPES_H
+#define _LINUX_WAVL_TYPES_H
+
+/*
+ * Weak AVL (WAVL) Trees — rank-balanced binary search trees.
+ *
+ * Compared to red-black trees, WAVL trees perform at most 2 rotations
+ * per insert/delete while maintaining O(log n) height.  Balance is
+ * tracked via integer ranks: every parent-child rank difference is
+ * 1 or 2, leaves have rank 0, and NULL has conceptual rank -1.
+ */
+
+struct wavl_node {
+	unsigned long __wavl_parent;
+	struct wavl_node *wavl_right;
+	struct wavl_node *wavl_left;
+	int rank;
+} __attribute__((aligned(sizeof(long))));
+
+struct wavl_root {
+	struct wavl_node *wavl_node;
+};
+
+struct wavl_root_cached {
+	struct wavl_root wavl_root;
+	struct wavl_node *wavl_leftmost;
+};
+
+#define WAVL_ROOT (struct wavl_root) { NULL, }
+#define WAVL_ROOT_CACHED (struct wavl_root_cached) { {NULL, }, NULL }
+
+#endif
