+
+/*
+ * WAVL-backed augmented rbtree API proxy.
+ *
+ * Include this INSTEAD of <linux/rbtree_augmented.h> to transparently
+ * replace augmented red-black tree operations with WAVL tree operations
+ * while keeping the rb_* naming convention.
+ */
+
+#include <linux/wavl_augmented.h>
+#include <linux/rbtree_wavl.h>
+
+/* Augmented callback type */
+#define rb_augment_callbacks	wavl_augment_callbacks
+
+/* Augmented insertion */
+#define __rb_insert_augmented	__wavl_insert_augmented
+#define rb_insert_augmented	wavl_insert_augmented
+#define rb_insert_augmented_cached wavl_insert_augmented_cached
+
+/* Augmented add (insert with less-than comparator) */
+#define rb_add_augmented_cached	wavl_add_augmented_cached
+
+/* Augmented callback declaration macros */
+#define RB_DECLARE_CALLBACKS	WAVL_DECLARE_CALLBACKS
+#define RB_DECLARE_CALLBACKS_MAX WAVL_DECLARE_CALLBACKS_MAX
+
+/* Augmented erase */
+#define __rb_erase_augmented	__wavl_erase_augmented
+#define rb_erase_augmented	wavl_erase_augmented
+#define rb_erase_augmented_cached wavl_erase_augmented_cached
+
+#endif	/* _LINUX_RBTREE_WAVL_AUGMENTED_H */
